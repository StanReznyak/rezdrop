APP_NAME=RezDrop
APP_VERSION=0.4.16
APP_ENV=local
APP_HOST=127.0.0.1
APP_PORT=8080
APP_SECRET_KEY=change-me-local-secret-key
COOKIE_SECURE=false
SESSION_MAX_AGE_SECONDS=604800
ALLOWED_HOSTS=127.0.0.1,localhost
ENABLE_API_DOCS=true

# Local Windows mode: SQLite + local disk storage
DATABASE_URL=sqlite:///./rezdrop_dev.db
PUBLIC_BASE_URL=http://127.0.0.1:8080
UPLOAD_DIR=uploads

MAX_UPLOAD_MB=512
MAX_TOTAL_UPLOAD_MB=2048
MAX_FILES_PER_UPLOAD=50
UPLOAD_RATE_LIMIT_PER_HOUR=30
AUTH_RATE_LIMIT_PER_HOUR=40
AUTH_FAIL_RATE_LIMIT_PER_15_MIN=10

ANTIVIRUS_MODE=basic
BLOCKED_EXTENSIONS=.bat,.cmd,.com,.scr,.vbs,.js,.jse,.wsf,.ps1,.msi,.jar,.exe

ENABLE_BACKGROUND_CLEANUP=true
CLEANUP_INTERVAL_SECONDS=600

ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
ADMIN_PASSWORD=change-me-local-password

STORAGE_BACKEND=local
