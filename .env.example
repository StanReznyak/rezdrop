APP_NAME=RezDrop
APP_VERSION=0.4.16
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8080
APP_SECRET_KEY=
COOKIE_SECURE=true
SESSION_MAX_AGE_SECONDS=604800
ALLOWED_HOSTS=example.com
ENABLE_API_DOCS=false

# PostgreSQL production database
POSTGRES_PASSWORD=
DATABASE_URL=
PUBLIC_BASE_URL=https://example.com
UPLOAD_DIR=/app/uploads

MAX_UPLOAD_MB=512
MAX_TOTAL_UPLOAD_MB=2048
MAX_FILES_PER_UPLOAD=50
UPLOAD_RATE_LIMIT_PER_HOUR=30
AUTH_RATE_LIMIT_PER_HOUR=40
AUTH_FAIL_RATE_LIMIT_PER_15_MIN=10

ANTIVIRUS_MODE=basic
BLOCKED_EXTENSIONS=.bat,.cmd,.com,.scr,.vbs,.js,.jse,.wsf,.ps1,.msi,.jar,.exe

ENABLE_BACKGROUND_CLEANUP=true
CLEANUP_INTERVAL_SECONDS=600

ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
ADMIN_PASSWORD=

# local = disk uploads; s3 = MinIO/S3 compatible storage
STORAGE_BACKEND=s3
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=rezdrop
S3_REGION=us-east-1
S3_PRESIGNED_TTL_SECONDS=3600
S3_AUTO_CREATE_BUCKET=true
